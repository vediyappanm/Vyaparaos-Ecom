# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5433/database_name
# Example: postgresql://bazaar_user:your_secure_password@localhost:5433/bazaar_mitr

# JWT Secret (REQUIRED - use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# Generate with: openssl rand -base64 32

# API Configuration
API_PORT=3001

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081
# In production, set to your actual domain: https://yourdomain.com

# Frontend Configuration
VITE_API_URL=http://localhost:3001

# NVIDIA AI Configuration
NVIDIA_API_KEY=replace-with-your-nvidia-api-key
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
